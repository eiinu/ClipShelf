{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipShelf",
  "version": "0.1.0",
  "identifier": "me.eiinu.clipshelf",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClipShelf",
        "width": 1500,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.png"]
  }
}
